---
// 3 application cards. TODO: replace with the real, prioritized use cases once
// validated with pilot customers.
const cases = [
  {
    title: 'Constellation operations',
    body: 'Plan station-keeping and collision-avoidance maneuvers around drag forecasts instead of reacting to them — and keep more satellites in their slots.',
    icon: 'orbit',
  },
  {
    title: 'Mission & launch planning',
    body: 'Size propellant budgets and choose operations windows with altitude-specific environment forecasts, before the design is locked.',
    icon: 'trajectory',
  },
  {
    title: 'Anomaly & risk analysis',
    body: 'Correlate on-orbit anomalies with radiation and charging conditions, and brief insurers and stakeholders with quantified, defensible data.',
    icon: 'shield',
  },
];
---

<section id="use-cases" class="border-t border-white/5 bg-void/40">
  <div class="mx-auto max-w-content px-5 py-20 sm:px-8 sm:py-28">
    <div class="reveal max-w-2xl">
      <p class="eyebrow mb-4">Use cases</p>
      <h2 class="text-balance text-3xl font-semibold tracking-tight text-white sm:text-4xl">
        Built for the decisions that don’t wait for the sun.
      </h2>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-3">
      {
        cases.map((c) => (
          <article class="reveal card flex flex-col p-7">
            <span class="flex h-11 w-11 items-center justify-center rounded-xl border border-white/10 bg-white/5 text-solar-400">
              {c.icon === 'orbit' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <circle cx="12" cy="12" r="2.5" fill="currentColor" />
                  <ellipse cx="12" cy="12" rx="10" ry="4.5" stroke="currentColor" stroke-width="1.5" transform="rotate(30 12 12)" />
                </svg>
              )}
              {c.icon === 'trajectory' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M3 20c4-1 6-3 8-8s5-8 9-9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="0.5 3.2" />
                  <circle cx="20" cy="3" r="2" fill="currentColor" />
                </svg>
              )}
              {c.icon === 'shield' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                  <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
            </span>
            <h3 class="mt-5 text-lg font-semibold text-white">{c.title}</h3>
            <p class="mt-2.5 text-sm leading-relaxed text-slate-400">{c.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
