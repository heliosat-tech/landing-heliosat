---
/**
 * Pure-SVG, line-art orbital motif for the hero. No raster images, no JS.
 * Decorative only — hidden from assistive tech.
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class:list={['relative select-none', className]} aria-hidden="true">
  <svg
    viewBox="0 0 480 480"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class="h-full w-full"
  >
    <defs>
      <radialGradient id="sun" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#FFE7BD" />
        <stop offset="45%" stop-color="#F5A524" />
        <stop offset="100%" stop-color="#D9871A" />
      </radialGradient>
      <linearGradient id="orbitStroke" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="rgba(255,255,255,0.45)" />
        <stop offset="60%" stop-color="rgba(255,255,255,0.10)" />
        <stop offset="100%" stop-color="rgba(255,255,255,0.02)" />
      </linearGradient>
    </defs>

    <!-- faint outer ring grid -->
    <circle cx="240" cy="240" r="218" stroke="rgba(255,255,255,0.06)" stroke-width="1" />

    <!-- central star (the "Helio") with soft glow -->
    <circle cx="240" cy="240" r="40" fill="url(#sun)" />
    <circle cx="240" cy="240" r="58" stroke="rgba(245,165,36,0.35)" stroke-width="1" />

    <!-- slowly rotating orbital system -->
    <g class="motion-safe:animate-spin-slow" style="transform-origin:240px 240px">
      <!-- orbit 1 -->
      <ellipse
        cx="240"
        cy="240"
        rx="118"
        ry="118"
        stroke="url(#orbitStroke)"
        stroke-width="1.25"
      />
      <circle cx="358" cy="240" r="5" fill="#FFBE6B" />

      <!-- orbit 2 (tilted) -->
      <ellipse
        cx="240"
        cy="240"
        rx="168"
        ry="92"
        stroke="url(#orbitStroke)"
        stroke-width="1.25"
        transform="rotate(28 240 240)"
      />
      <circle cx="92" cy="190" r="4" fill="#E6EAF2" />

      <!-- orbit 3 (tilted other way) -->
      <ellipse
        cx="240"
        cy="240"
        rx="205"
        ry="120"
        stroke="url(#orbitStroke)"
        stroke-width="1.25"
        transform="rotate(-22 240 240)"
      />
      <circle cx="430" cy="300" r="3.5" fill="#9AA4B8" />
    </g>

    <!-- crosshair guide lines -->
    <line x1="240" y1="8" x2="240" y2="58" stroke="rgba(255,255,255,0.10)" stroke-width="1" />
    <line x1="240" y1="422" x2="240" y2="472" stroke="rgba(255,255,255,0.10)" stroke-width="1" />
    <line x1="8" y1="240" x2="58" y2="240" stroke="rgba(255,255,255,0.10)" stroke-width="1" />
    <line x1="422" y1="240" x2="472" y2="240" stroke="rgba(255,255,255,0.10)" stroke-width="1" />
  </svg>
</div>
