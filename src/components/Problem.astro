---
// 2–3 short, specific statements about the pain the target customer feels today.
// TODO: validate these against real operator interviews.
const problems = [
  {
    n: '01',
    title: 'The data is fragmented',
    body: 'Operators stitch together public indices, TLEs, and spreadsheets. By the time a drag spike or radiation event is obvious, the window to act has already closed.',
  },
  {
    n: '02',
    title: 'Global indices are too coarse to act on',
    body: 'Kp and F10.7 describe the whole planet. They don’t tell you what’s happening at your altitude, your inclination, or your specific spacecraft.',
  },
  {
    n: '03',
    title: 'Every anomaly is expensive',
    body: 'Unplanned safe-modes, wasted propellant, and missed maneuver windows turn a quiet sun into real operational cost — and hard questions from stakeholders.',
  },
];
---

<section id="problem" class="mx-auto max-w-content px-5 py-20 sm:px-8 sm:py-28">
  <div class="reveal max-w-2xl">
    <p class="eyebrow mb-4">The problem</p>
    <h2 class="text-balance text-3xl font-semibold tracking-tight text-white sm:text-4xl">
      Space weather is operational risk you can’t currently see.
    </h2>
    <p class="mt-4 text-lg leading-relaxed text-slate-400">
      Satellites in low Earth orbit live inside a dynamic environment. Most teams
      are forced to react to it instead of planning around it.
    </p>
  </div>

  <div class="mt-12 grid gap-5 sm:grid-cols-3">
    {
      problems.map((p) => (
        <div class="reveal card p-6">
          <span class="font-mono text-sm text-solar-400">{p.n}</span>
          <h3 class="mt-3 text-lg font-semibold text-white">{p.title}</h3>
          <p class="mt-2.5 text-sm leading-relaxed text-slate-400">{p.body}</p>
        </div>
      ))
    }
  </div>
</section>
