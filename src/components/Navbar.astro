---
import DemoButton from './DemoButton.astro';
import { SITE } from '../consts';
---

<header
  class="sticky top-0 z-40 border-b border-white/5 bg-ink/70 backdrop-blur-md"
>
  <nav
    class="mx-auto flex h-16 max-w-content items-center justify-between px-5 sm:px-8"
    aria-label="Primary"
  >
    <a href="#top" class="group flex items-center gap-2.5" aria-label={`${SITE.name} home`}>
      <!-- small orbital glyph -->
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <circle cx="11" cy="11" r="3.4" fill="#F5A524" />
        <ellipse
          cx="11"
          cy="11"
          rx="9.4"
          ry="4.4"
          stroke="rgba(255,255,255,0.45)"
          stroke-width="1.1"
          transform="rotate(28 11 11)"
        />
      </svg>
      <span class="text-[1.05rem] font-semibold tracking-tight text-white">
        {SITE.name}
      </span>
    </a>

    <DemoButton variant="primary" class="!px-4 !py-2 text-sm" />
  </nav>
</header>
