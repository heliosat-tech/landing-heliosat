---
import { SITE } from '../consts';
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5">
  <div
    class="mx-auto flex max-w-content flex-col gap-6 px-5 py-10 sm:flex-row sm:items-center sm:justify-between sm:px-8"
  >
    <div class="flex items-center gap-2.5">
      <svg width="18" height="18" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <circle cx="11" cy="11" r="3" fill="#F5A524" />
        <ellipse cx="11" cy="11" rx="9" ry="4.2" stroke="rgba(255,255,255,0.4)" stroke-width="1" transform="rotate(28 11 11)" />
      </svg>
      <span class="text-sm font-semibold text-white">{SITE.name}</span>
      <span class="text-sm text-slate-600">© {year}</span>
    </div>

    <nav class="flex items-center gap-6 text-sm" aria-label="Footer">
      <!-- TODO: replace with the real contact inbox. -->
      <a
        href={`mailto:${SITE.email}`}
        class="text-slate-400 transition-colors hover:text-white"
      >
        {SITE.email}
      </a>
      <!-- TODO: replace with the real company LinkedIn URL. -->
      <a
        href={SITE.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-slate-400 transition-colors hover:text-white"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.83-2.05 3.76-2.05C21.4 8.65 22 11.1 22 14.3V21h-4v-5.9c0-1.4 0-3.2-1.95-3.2-1.96 0-2.26 1.53-2.26 3.1V21h-4z" />
        </svg>
        LinkedIn
      </a>
    </nav>
  </div>

  <p class="mx-auto max-w-content px-5 pb-8 text-xs text-slate-600 sm:px-8">
    HelioSat is in active pilot phase. Product details on this page are
    illustrative and subject to change.
    <!-- TODO: remove or update this disclaimer when the product is generally available. -->
  </p>
</footer>
